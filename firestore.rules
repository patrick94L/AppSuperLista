rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Family rules
    match /families/{familyId} {
      // Members can read their family
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      // Any authenticated user can create a family
      allow create: if request.auth != null;
      // Members can update (e.g. join)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );

      // Shopping list subcollection
      match /shoppingList/{itemId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }
    }
  }
}
